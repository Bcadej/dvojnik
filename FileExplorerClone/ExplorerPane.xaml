<UserControl x:Class="FileExplorerClone.ExplorerPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FileExplorerClone"
             FontSize="{StaticResource AppFontSize}">
    <UserControl.Resources>
        <local:CompareStateToBrushConverter x:Key="CompareBrushConverter"/>
    </UserControl.Resources>
    <DockPanel LastChildFill="True">

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top">
            <Button x:Name="BackButton" Content="&#x2190;" Click="BackButton_Click" Width="32"
                    ToolTip="{Binding [Pane_Back], Source={x:Static local:Loc.Instance}}"/>
            <Button x:Name="ForwardButton" Content="&#x2192;" Click="ForwardButton_Click" Width="32"
                    ToolTip="{Binding [Pane_Forward], Source={x:Static local:Loc.Instance}}"/>
            <Button x:Name="UpButton" Content="&#x2191;" Click="UpButton_Click" Width="32"
                    ToolTip="{Binding [Pane_Up], Source={x:Static local:Loc.Instance}}"/>
            <Button x:Name="RefreshButton" Content="&#x21BB;" Click="RefreshButton_Click" Width="32"
                    ToolTip="{Binding [Pane_Refresh], Source={x:Static local:Loc.Instance}}"/>
            <Separator/>
            <TextBox x:Name="AddressBar" Width="280" VerticalAlignment="Center" KeyDown="AddressBar_KeyDown"/>
            <Button Click="GoButton_Click" MinWidth="44" Padding="6,2"
                    Content="{Binding [Pane_Go], Source={x:Static local:Loc.Instance}}"/>
        </ToolBar>

        <!-- Shortcut bar: drop targets the user builds up by dragging folders/files here -->
        <Border DockPanel.Dock="Top" MinHeight="36"
                Background="#F7F9FC" BorderBrush="#DDE3EC" BorderThickness="0,0,0,1"
                AllowDrop="True"
                DragOver="ShortcutBar_DragOver"
                Drop="ShortcutBar_Drop">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Click="RemoveAllShortcuts_Click"
                              Header="{Binding [Shortcut_RemoveAll], Source={x:Static local:Loc.Instance}}"/>
                </ContextMenu>
            </Border.ContextMenu>
            <Grid>
                <TextBlock x:Name="ShortcutHint" Margin="10,0" VerticalAlignment="Center"
                           Foreground="#8A94A6" FontStyle="Italic" IsHitTestVisible="False"
                           Text="{Binding [Shortcuts_Hint], Source={x:Static local:Loc.Instance}}"/>
                <ItemsControl x:Name="ShortcutList" Margin="4,3">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Click="Shortcut_Click" Margin="3,2" Padding="8,3"
                                    ToolTip="{Binding FullPath}" Cursor="Hand"
                                    AutomationProperties.Name="{Binding Name}">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Click="RenameShortcut_Click"
                                                  Header="{Binding [Shortcut_Rename], Source={x:Static local:Loc.Instance}}"/>
                                        <MenuItem Click="RemoveShortcut_Click"
                                                  Header="{Binding [Shortcut_Remove], Source={x:Static local:Loc.Instance}}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- File list -->
        <ListView x:Name="FileListView"
                  DockPanel.Dock="Bottom"
                  MouseDoubleClick="FileListView_MouseDoubleClick"
                  PreviewKeyDown="FileListView_PreviewKeyDown"
                  SelectionMode="Extended"
                  AllowDrop="True"
                  GridViewColumnHeader.Click="ColumnHeader_Click"
                  PreviewMouseLeftButtonDown="FileListView_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="FileListView_PreviewMouseMove"
                  DragOver="FileListView_DragOver"
                  Drop="FileListView_Drop">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                    <Setter Property="Background" Value="{Binding CompareState, Converter={StaticResource CompareBrushConverter}}"/>
                    <Style.Triggers>
                        <!-- Sync View spacers are not real rows: the arrow keys must step
                             straight over them, and they must never be selectable. -->
                        <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Click="OpenMenuItem_Click"
                              Header="{Binding [Menu_Open], Source={x:Static local:Loc.Instance}}"/>
                    <MenuItem Click="RenameMenuItem_Click"
                              Header="{Binding [Menu_Rename], Source={x:Static local:Loc.Instance}}"/>
                    <MenuItem Click="DeleteMenuItem_Click"
                              Header="{Binding [Menu_Delete], Source={x:Static local:Loc.Instance}}"/>
                    <Separator/>
                    <MenuItem Click="CopyMenuItem_Click"
                              Header="{Binding [Menu_Copy], Source={x:Static local:Loc.Instance}}"/>
                    <MenuItem Click="CutMenuItem_Click"
                              Header="{Binding [Menu_Cut], Source={x:Static local:Loc.Instance}}"/>
                    <MenuItem Click="PasteMenuItem_Click"
                              Header="{Binding [Menu_Paste], Source={x:Static local:Loc.Instance}}"/>
                    <Separator/>
                    <MenuItem Click="AddToShortcutsMenuItem_Click"
                              Header="{Binding [Shortcut_Add], Source={x:Static local:Loc.Instance}}"/>
                    <Separator/>
                    <MenuItem Click="NewFolderMenuItem_Click"
                              Header="{Binding [Menu_NewFolder], Source={x:Static local:Loc.Instance}}"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="280">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Name"
                                    AutomationProperties.Name="{Binding [Column_Name], Source={x:Static local:Loc.Instance}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding [Column_Name], Source={x:Static local:Loc.Instance}}"/>
                                    <TextBlock x:Name="NameSortArrow" Margin="5,0,0,0" FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </GridViewColumnHeader>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="90" DisplayMemberBinding="{Binding SizeLabel}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Size"
                                    AutomationProperties.Name="{Binding [Column_Size], Source={x:Static local:Loc.Instance}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding [Column_Size], Source={x:Static local:Loc.Instance}}"/>
                                    <TextBlock x:Name="SizeSortArrow" Margin="5,0,0,0" FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </GridViewColumnHeader>
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <GridViewColumn Width="120" DisplayMemberBinding="{Binding TypeLabel}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Type"
                                    AutomationProperties.Name="{Binding [Column_Type], Source={x:Static local:Loc.Instance}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding [Column_Type], Source={x:Static local:Loc.Instance}}"/>
                                    <TextBlock x:Name="TypeSortArrow" Margin="5,0,0,0" FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </GridViewColumnHeader>
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <GridViewColumn Width="160" DisplayMemberBinding="{Binding ModifiedLabel}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Modified"
                                    AutomationProperties.Name="{Binding [Column_Modified], Source={x:Static local:Loc.Instance}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding [Column_Modified], Source={x:Static local:Loc.Instance}}"/>
                                    <TextBlock x:Name="ModifiedSortArrow" Margin="5,0,0,0" FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </GridViewColumnHeader>
                        </GridViewColumn.Header>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>
