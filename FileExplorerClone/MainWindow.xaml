<Window x:Class="FileExplorerClone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FileExplorerClone"
        Title="{Binding [App_Title], Source={x:Static local:Loc.Instance}}"
        Height="760" Width="1280"
        FontSize="{StaticResource AppFontSize}"
        Icon="Resources/Dvojnik.ico">
    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{Binding [Menu_Language], Source={x:Static local:Loc.Instance}}">
                <MenuItem x:Name="SlovenianMenuItem"
                          Header="{Binding [Menu_Language_Slovenian], Source={x:Static local:Loc.Instance}}"
                          IsCheckable="True" Click="SlovenianMenuItem_Click"/>
                <MenuItem x:Name="EnglishMenuItem"
                          Header="{Binding [Menu_Language_English], Source={x:Static local:Loc.Instance}}"
                          IsCheckable="True" Click="EnglishMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="{Binding [Menu_Help], Source={x:Static local:Loc.Instance}}">
                <MenuItem Header="{Binding [Menu_Help_About], Source={x:Static local:Loc.Instance}}"
                          Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <!-- Checked/Unchecked rather than Click: the state also changes via keyboard and
                 automation, and those paths never raise Click. -->
            <ToggleButton x:Name="SyncToggle" Padding="8,3" MinWidth="200"
                          Checked="SyncToggle_Changed" Unchecked="SyncToggle_Changed"
                          Content="{Binding [Toolbar_SyncOff], Source={x:Static local:Loc.Instance}}"/>
            <Separator/>
            <Button Click="SwapButton_Click" Padding="8,3"
                    Content="{Binding [Toolbar_SwapPanes], Source={x:Static local:Loc.Instance}}"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="Gray"/>
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <local:ExplorerPane x:Name="LeftPane" Grid.Column="0" PaneId="Left"/>
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#DDD"/>
            <local:ExplorerPane x:Name="RightPane" Grid.Column="2" PaneId="Right"/>
        </Grid>
    </DockPanel>
</Window>
