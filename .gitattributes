# Normalise line endings so the repo stays consistent across machines.
* text=auto

# Windows tooling is happier with CRLF for these.
*.sln       text eol=crlf
*.csproj    text eol=crlf
*.props     text eol=crlf
*.ps1       text eol=crlf
*.xaml      text eol=crlf
*.cs        text eol=crlf
*.resx      text eol=crlf

# Never touch binary content.
*.ico       binary
*.png       binary
*.exe       binary
*.dll       binary
